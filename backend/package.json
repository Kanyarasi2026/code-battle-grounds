{
	"name": "backend",
	"version": "1.0.0",
	"description": "backend for code-battle-grounds hackathon project",
	"homepage": "https://github.com/Kanyarasi2026/code-battle-grounds",
	"bugs": {
		"url": "https://github.com/Kanyarasi2026/code-battle-grounds/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Kanyarasi2026/code-battle-grounds.git"
	},
	"license": "ISC",
	"author": "meghan31.me",
	"type": "module",
	"main": "src/index.ts",
	"scripts": {
		"start": "node --loader ts-node/esm src/index.ts",
		"dev": "nodemon --exec 'node --loader ts-node/esm' src/index.ts",
		"devw": "nodemon --exec node --loader ts-node/esm src/index.ts",
		"build": "tsc",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage"
	},
	"dependencies": {
		"@supabase/supabase-js": "^2.81.1",
		"cors": "^2.8.5",
		"dotenv": "^17.2.3",
		"express": "^4.21.2",
		"joi": "^18.0.1",
		"rate-limiter-flexible": "^8.1.0",
		"socket.io": "^4.8.1",
		"winston": "^3.18.3"
	},
	"devDependencies": {
		"@types/cors": "^2.8.17",
		"@types/express": "^4.17.21",
		"@types/node": "^22.0.0",
		"@types/supertest": "^6.0.2",
		"@vitest/coverage-v8": "^3.0.0",
		"nodemon": "^3.1.14",
		"supertest": "^7.0.0",
		"ts-node": "^10.9.2",
		"typescript": "^5.9.3",
		"vitest": "^3.0.0"
	}
}
